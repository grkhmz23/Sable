    },
    {
      "name": "TransferBatchEvent",
      "fields": [
        { "name": "fromOwner", "type": "publicKey", "index": false },
        { "name": "mint", "type": "publicKey", "index": false },
        { "name": "recipientCount", "type": "u16", "index": false },
        { "name": "totalAmount", "type": "u64", "index": false },
        { "name": "stateVersion", "type": "u64", "index": false }
      ]
    },
    {
      "name": "WithdrawEvent",
      "fields": [
        { "name": "owner", "type": "publicKey", "index": false },
        { "name": "mint", "type": "publicKey", "index": false },
        { "name": "amount", "type": "u64", "index": false },
        { "name": "newBalance", "type": "u64", "index": false },
        { "name": "stateVersion", "type": "u64", "index": false }
      ]
    },
    {
      "name": "DelegateEvent",
      "fields": [
        { "name": "owner", "type": "publicKey", "index": false },
        { "name": "mintCount", "type": "u8", "index": false },
        { "name": "mints", "type": { "vec": "publicKey" }, "index": false }
      ]
    },
    {
      "name": "CommitUndelegateEvent",
      "fields": [
        { "name": "owner", "type": "publicKey", "index": false },
        { "name": "mintCount", "type": "u8", "index": false },
        { "name": "mints", "type": { "vec": "publicKey" }, "index": false }
      ]
    }
