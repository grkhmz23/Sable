    {
      "name": "withdraw",
      "accounts": [
        { "name": "owner", "isMut": true, "isSigner": true },
        { "name": "userState", "isMut": true, "isSigner": false },
        { "name": "userBalance", "isMut": true, "isSigner": false },
        { "name": "mint", "isMut": false, "isSigner": false },
        { "name": "vaultAuthority", "isMut": false, "isSigner": false },
