        { "name": "mint", "type": "publicKey", "index": false }
      ]
    },
    {
      "name": "DepositEvent",
      "fields": [
        { "name": "owner", "type": "publicKey", "index": false },
        { "name": "mint", "type": "publicKey", "index": false },
