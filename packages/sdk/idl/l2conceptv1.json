      "args": [{ "name": "mintList", "type": { "vec": "publicKey" } }]
    },
    {
      "name": "commitAndUndelegateUserStateAndBalances",
      "accounts": [
        { "name": "payer", "isMut": true, "isSigner": true },
        { "name": "owner", "isMut": false, "isSigner": false },
        { "name": "userState", "isMut": true, "isSigner": false },
        { "name": "magicContext", "isMut": false, "isSigner": false },
        { "name": "magicProgram", "isMut": false, "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [{ "name": "mintList", "type": { "vec": "publicKey" } }]
    }
