  "accounts": [
    {
      "name": "Config",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "admin", "type": "publicKey" },
          { "name": "delegationProgramId", "type": "publicKey" },
          { "name": "bump", "type": "u8" }
