# Sable Environment Variables

# Required: Solana RPC URL
# Examples:
#   Localnet: http://127.0.0.1:8899
#   Devnet: https://api.devnet.solana.com
#   Mainnet: https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=http://127.0.0.1:8899

# Optional: MagicBlock Ephemeral Rollup RPC URL
# Only needed if using ER features
NEXT_PUBLIC_MAGICBLOCK_RPC_URL=

# Required: Program ID for Sable
# Default is a placeholder - replace with your deployed program ID
NEXT_PUBLIC_SABLE_PROGRAM_ID=SABLE_PROGRAM_ID_TBD
