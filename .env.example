# Sable Environment Variables

# Required: Solana RPC URL
# Examples:
#   Localnet: http://127.0.0.1:8899
#   Devnet: https://api.devnet.solana.com
#   Mainnet: https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=http://127.0.0.1:8899

# Optional: MagicBlock Ephemeral Rollup RPC URL
# Only needed if using ER features
NEXT_PUBLIC_MAGICBLOCK_RPC_URL=

# Required: Program ID for Sable
NEXT_PUBLIC_SABLE_PROGRAM_ID=SaSAXcdWhyr1KD8TKRg6K7WPuxcPLZJHKEwsjQgL5Di

# Deployer keypair path (used by scripts/deploy-devnet.sh)
# NEVER commit keypair files to git. They are already gitignored in keys/.
SABLE_DEPLOYER_KEYPAIR=keys/deployer-keypair.json

# Devnet RPC endpoint (used by scripts/init-devnet.ts)
SABLE_DEVNET_RPC=https://api.devnet.solana.com

# MagicBlock RPC endpoint for PER/session key testing
# Request access via MagicBlock Discord
SABLE_MAGICBLOCK_RPC=

# Private Payments API (MagicBlock hosted)
# Set to the mock server URL for local development: http://localhost:4444
SABLE_PRIVATE_PAYMENTS_API_URL=
SABLE_PRIVATE_PAYMENTS_API_KEY=
NEXT_PUBLIC_SABLE_PRIVATE_PAYMENTS_API_URL=http://localhost:4444
NEXT_PUBLIC_SABLE_PRIVATE_PAYMENTS_API_KEY=

# PER Mock Middleware (local development)
# Set to the mock middleware URL for local development: http://localhost:3333
NEXT_PUBLIC_SABLE_PER_MOCK_URL=http://localhost:3333
