{
  "name": "sable",
  "version": "1.0.0",
  "description": "Sable — private programmable money for AI agents on Solana, built on MagicBlock ER + PER + Private Payments API",
  "private": true,
  "scripts": {
    "install:all": "pnpm install",
    "anchor:build": "cd programs/sable && cargo build-sbf",
    "anchor:test": "cd programs/sable && anchor test",
    "anchor:deploy:devnet": "cd programs/sable && anchor deploy --provider.cluster devnet",
    "app:dev": "cd app && pnpm dev",
    "app:build": "cd app && pnpm build",
    "app:lint": "cd app && pnpm lint",
    "app:typecheck": "cd app && pnpm typecheck",
    "idl:sync": "node scripts/idl-sync.js",
    "build:all": "pnpm -r build",
    "build": "pnpm build:all",
    "clean": "find . -type d -name node_modules -exec rm -rf {} + 2>/dev/null; find . -type d -name target -exec rm -rf {} + 2>/dev/null; find . -type d -name dist -exec rm -rf {} + 2>/dev/null; echo 'Cleaned build artifacts'",
    "lint": "pnpm -r lint",
    "lint:root": "eslint . --ext .ts,.js --ignore-pattern '**/node_modules/**' --ignore-pattern '**/target/**' --ignore-pattern '**/dist/**'",
    "typecheck": "pnpm -r typecheck",
    "typecheck:root": "tsc --noEmit",
    "test": "pnpm anchor:test",
    "test:integration": "bash scripts/test-integration.sh",
    "test:integration:live": "bash scripts/test-integration.sh --live",
    "verify": "pnpm lint && pnpm typecheck && pnpm build:all"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "chai": "^6.2.2",
    "eslint": "^8.55.0",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
